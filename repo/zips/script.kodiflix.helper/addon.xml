<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.kodiflix.helper" name="Kodiflix Helper" version="1.0.5" provider-name="Jack Davison">
	<requires>
		<import addon="xbmc.python" version="3.0.0"/>
	</requires>
	<extension point="xbmc.python.library" library="resources/lib/default.py"/>
	<extension point="xbmc.service" library="resources/lib/service.py" start="startup"/>
	<extension point="xbmc.addon.metadata">
		<summary lang="en_GB">Adaptive artwork processing for Kodiflix</summary>
		<description lang="en_GB">Generates cached adaptive blurred backgrounds from artwork exposed by the Kodiflix skin.</description>
		<platform>all</platform>
		<license>GPL-2.0-only</license>
	</extension>
</addon>





