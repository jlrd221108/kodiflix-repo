						<label2>[B]$VAR[FlixBlurStrengthLabelVar][/B]</label2>
						<onclick condition="String.IsEqual(Skin.String(Kodiflix.BlurRadius),60)">Skin.SetString(Kodiflix.BlurRadius,5)</onclick>
						<onclick condition="String.IsEqual(Skin.String(Kodiflix.BlurRadius),30)">Skin.SetString(Kodiflix.BlurRadius,60)</onclick>
						<onclick condition="String.IsEqual(Skin.String(Kodiflix.BlurRadius),15)">Skin.SetString(Kodiflix.BlurRadius,30)</onclick>
