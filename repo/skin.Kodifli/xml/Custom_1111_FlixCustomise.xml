<?xml version="1.0" encoding="utf-8"?>
<window type="dialog" id="1111">
	<onload condition="String.IsEmpty(Skin.String(Kodiflix.BlurRadius))">Skin.SetString(Kodiflix.BlurRadius,30)</onload>
	<onload condition="String.IsEmpty(Skin.String(Kodiflix.BlurSaturation))">Skin.SetString(Kodiflix.BlurSaturation,1.5)</onload>
	<onload condition="String.IsEqual(Skin.String(Kodiflix.BlurRadius),20)">Skin.SetString(Kodiflix.BlurRadius,15)</onload>
	<onload condition="String.IsEqual(Skin.String(Kodiflix.BlurRadius),40) | String.IsEqual(Skin.String(Kodiflix.BlurRadius),50)">Skin.SetString(Kodiflix.BlurRadius,60)</onload>
	<onload condition="String.IsEqual(Skin.String(Kodiflix.BlurSaturation),1.0)">Skin.SetString(Kodiflix.BlurSaturation,0.35)</onload>
	<onload condition="String.IsEqual(Skin.String(Kodiflix.BlurSaturation),2.0)">Skin.SetString(Kodiflix.BlurSaturation,3.0)</onload>
	<onload condition="String.IsEmpty(Skin.String(Kodiflix.AgeRatingStyle))">Skin.SetString(Kodiflix.AgeRatingStyle,Legacy)</onload>
	<onload condition="String.IsEmpty(Skin.String(Kodiflix.AgeRatingPosition))">Skin.SetString(Kodiflix.AgeRatingPosition,Center)</onload>
