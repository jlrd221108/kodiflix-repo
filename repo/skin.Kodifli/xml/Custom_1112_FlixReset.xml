<?xml version="1.0" encoding="utf-8"?>
<window type="dialog" id="1112">
	<defaultcontrol always="true">10</defaultcontrol>
	<include>Animation_DialogPopupOpenClose</include>
	<controls>
		<control type="group">
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>680</width>
			<height>370</height>
			<include content="DialogBackgroundCommons">
				<param name="width" value="680" />
				<param name="height" value="370" />
				<param name="header_label" value="Reset Flix customisation?" />
				<param name="header_id" value="" />
			</include>
			<control type="textbox">
				<left>40</left>
				<top>105</top>
				<width>600</width>
				<height>115</height>
				<font>font25_title</font>
				<align>center</align>
				<label>This will restore the default blur, progress indicator and age rating options across every Flix view. This cannot be undone.</label>
			</control>
			<control type="grouplist" id="9000">
				<orientation>horizontal</orientation>
				<left>30</left>
				<top>250</top>
				<width>620</width>
				<height>80</height>
				<align>center</align>
				<itemgap>20</itemgap>
				<onback>Dialog.Close(1112)</onback>
				<include content="DefaultDialogButton">
					<param name="id" value="10" />
					<param name="width" value="270" />
					<param name="height" value="80" />
					<param name="label" value="Cancel" />
					<param name="onclick" value="Dialog.Close(1112)" />
				</include>
				<control type="button" id="11">
					<width>270</width>
					<height>80</height>
					<label>Reset</label>
					<font>font25_title</font>
					<align>center</align>
					<textoffsetx>20</textoffsetx>
					<texturefocus border="40" colordiffuse="button_focus">buttons/dialogbutton-fo.png</texturefocus>
					<texturenofocus border="40">buttons/dialogbutton-nofo.png</texturenofocus>
					<onclick>Skin.Reset(flix_disable_background_blur)</onclick>
					<onclick>Skin.SetBool(flix_hide_movie_progress)</onclick>
					<onclick>Skin.SetString(Kodiflix.BlurRadius,30)</onclick>
					<onclick>Skin.SetString(Kodiflix.BlurSaturation,1.5)</onclick>
					<onclick>Skin.SetString(Kodiflix.AgeRatingStyle,Legacy)</onclick>
					<onclick>Skin.SetString(Kodiflix.AgeRatingPosition,Center)</onclick>
					<onclick>Dialog.Close(1112)</onclick>
				</control>
			</control>
		</control>
	</controls>
</window>
