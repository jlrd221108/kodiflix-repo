<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>9000</defaultcontrol>
	<backgroundcolor>background</backgroundcolor>
	<controls>
		<include>DefaultBackground</include>
		<control type="image">
			<visible>Skin.HasSetting(KodiflixSettingsPopupStyle)</visible>
			<depth>DepthBackground</depth>
			<include>FullScreenDimensions</include>
			<aspectratio>scale</aspectratio>
			<texture>$VAR[KodiflixSettingsBackgroundVar]</texture>
		</control>
		<control type="multiimage">
			<visible>!Skin.HasSetting(KodiflixSettingsPopupStyle) + !Player.HasMedia + !String.IsEmpty(Skin.String(HomeFanart.path))</visible>
			<depth>DepthBackground</depth>
			<include>FullScreenDimensions</include>
			<aspectratio>scale</aspectratio>
			<imagepath colordiffuse="35FFFFFF">$INFO[Skin.String(HomeFanart.path)]settings$INFO[Skin.String(HomeFanart.ext)]</imagepath>
		</control>
		<control type="group">
			<visible>Skin.HasSetting(KodiflixSettingsPopupStyle)</visible>
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>705</width>
			<height>744</height>
			<include>Kodiflix_SettingsTextFade</include>
			<control type="list" id="9000">
				<left>0</left>
				<top>0</top>
				<width>705</width>
				<height>744</height>
				<onup>9000</onup>
				<ondown>9000</ondown>
				<scrolltime>0</scrolltime>
				<itemlayout height="62" width="705">
					<control type="image">
						<visible>!Skin.HasSetting(KodiflixSettingsSquareFocus)</visible>
						<left>0</left>
						<top>5</top>
						<width>705</width>
						<height>53</height>
						<texture border="20" colordiffuse="70000000">kodiflix/settings-panel-rounded.png</texture>
					</control>
<control type="image">
						<visible>Skin.HasSetting(KodiflixSettingsSquareFocus)</visible>
						<left>0</left>
						<top>5</top>
						<width>705</width>
						<height>53</height>
						<texture border="20" colordiffuse="70000000">kodiflix/settings-panel-square.png</texture>
					</control>
					<control type="image">
						<left>8</left>
						<top>-7</top>
						<width>76</width>
						<height>76</height>
						<texture colordiffuse="E8FFFFFF">$INFO[ListItem.Icon]</texture>
						<aspectratio>keep</aspectratio>
					</control>
					<control type="label">
						<left>90</left>
						<width>525</width>
						<height>62</height>
						<label>$INFO[ListItem.Label]</label>
						<font>font13</font>
						<textcolor>white</textcolor>
						<align>center</align>
						<aligny>center</aligny>
					</control>
				</itemlayout>
				<focusedlayout height="62" width="705">
					<control type="image">
						<visible>!Skin.HasSetting(KodiflixSettingsSquareFocus)</visible>
						<left>0</left>
						<top>5</top>
						<width>705</width>
						<height>53</height>
						<texture border="20" colordiffuse="60434A51">kodiflix/settings-panel-rounded.png</texture>
					</control>
<control type="image">
						<visible>Skin.HasSetting(KodiflixSettingsSquareFocus)</visible>
						<left>0</left>
						<top>5</top>
						<width>705</width>
						<height>53</height>
						<texture border="20" colordiffuse="60434A51">kodiflix/settings-panel-square.png</texture>
