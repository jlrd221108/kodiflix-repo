	<include name="View_56_Flix">
		<control type="group">
			<description>Flix movie, TV show and season viewtype</description>
			<visible>Control.IsVisible(56) | Control.IsVisible(57)</visible>
			<animation effect="fade" start="0" end="100" time="300">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
			<animation effect="fade" time="250">VisibleChange</animation>

			<!-- Artwork feed monitored by the external Kodiflix Helper service -->
			<control type="image" id="56000">
				<left>-3000</left>
				<top>-3000</top>
				<width>1</width>
				<height>1</height>
				<texture background="true">$VAR[MediaFanartVar]</texture>
				<visible>false</visible>
			</control>
			<control type="label" id="56001">
				<left>-3000</left>
				<top>-3000</top>
				<width>1</width>
				<height>1</height>
				<label>$INFO[ListItem.DBID]</label>
				<visible>false</visible>
			</control>
			<control type="label" id="56002">
				<left>-3000</left>
				<top>-3000</top>
				<width>1</width>
				<height>1</height>
				<label>$INFO[ListItem.DBType]</label>
				<visible>false</visible>
			</control>

			<!-- Background fallback -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>1920</width>
				<height>1080</height>
				<texture colordiffuse="FF050403">colors/white.png</texture>
			</control>

			<!-- Adaptive blur generated and cached by script.kodiflix.helper -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>1920</width>
				<height>1080</height>
				<aspectratio>scale</aspectratio>
				<fadetime>450</fadetime>
				<texture colordiffuse="FF5F5F5F">$INFO[Window(home).Property(kodiflix.helper.flix_blurred)]</texture>
				<visible>System.AddonIsEnabled(script.kodiflix.helper) + !String.IsEmpty(Window(home).Property(kodiflix.helper.flix_blurred)) + !Skin.HasSetting(flix_disable_background_blur)</visible>
			</control>
			<!-- Netflix-style selected fanart anchored top-right -->
			<control type="image">
				<left>640</left>
				<top>0</top>
				<width>1360</width>
				<height>720</height>
				<aspectratio align="right" aligny="top">scale</aspectratio>
				<fadetime>350</fadetime>
				<texture background="true" diffuse="special://skin/extras/flix-fanart-diffuse-v4.png" fallback="special://skin/extras/home-images/movie.jpg">$VAR[MediaFanartVar]</texture>
			</control>

			<!-- Clearlogo, with a text title when clearlogo artwork is unavailable -->
			<control type="image">
				<left>53</left>
				<top>65</top>
				<width>456</width>
				<height>190</height>
				<aspectratio align="center" aligny="center">keep</aspectratio>
				<fadetime>250</fadetime>
				<texture background="true">$VAR[FlixClearLogoVar]</texture>
				<visible>!String.IsEmpty(ListItem.Art(clearlogo)) | !String.IsEmpty(ListItem.Art(tvshow.clearlogo)) | !String.IsEmpty(Container.Art(tvshow.clearlogo))</visible>
			</control>
			<control type="label">
				<left>53</left>
				<top>82</top>
				<width>456</width>
				<height>150</height>
				<font>font60</font>
				<align>center</align>
				<aligny>center</aligny>
				<label>$VAR[FlixTitleVar]</label>
				<shadowcolor>DD000000</shadowcolor>
				<visible>!String.IsEqual(ListItem.DBType,season) + String.IsEmpty(ListItem.Art(clearlogo)) + String.IsEmpty(ListItem.Art(tvshow.clearlogo)) + String.IsEmpty(Container.Art(tvshow.clearlogo))</visible>
			</control>
			<control type="label">
				<left>53</left>
				<top>82</top>
				<width>456</width>
				<height>150</height>
				<font>font60</font>
				<align>center</align>
				<aligny>center</aligny>
				<label>$INFO[ListItem.TVShowTitle]</label>
				<shadowcolor>DD000000</shadowcolor>
				<visible>String.IsEqual(ListItem.DBType,season) + String.IsEmpty(ListItem.Art(clearlogo)) + String.IsEmpty(ListItem.Art(tvshow.clearlogo)) + String.IsEmpty(Container.Art(tvshow.clearlogo))</visible>
			</control>

			<!-- Movie metadata chips -->
			<control type="grouplist">
				<left>53</left>
				<top>296</top>
				<width>930</width>
				<height>43</height>
				<orientation>horizontal</orientation>
				<itemgap>19</itemgap>
				<usecontrolcoords>true</usecontrolcoords>
				<!-- Left means the first visible metadata item for every content type. -->
				<control type="group">
					<width>97</width>
					<visible>!String.IsEqual(ListItem.DBType,set) + !String.IsEmpty(ListItem.MPAA) + String.IsEqual(Skin.String(Kodiflix.AgeRatingPosition),Left)</visible>
					<control type="group">
						<visible>String.IsEmpty(Skin.String(Kodiflix.AgeRatingStyle)) | String.IsEqual(Skin.String(Kodiflix.AgeRatingStyle),Pill) | [String.IsEqual(Skin.String(Kodiflix.AgeRatingStyle),New) + !$EXP[flix_age_rating_new_available]] | [String.IsEqual(Skin.String(Kodiflix.AgeRatingStyle),Legacy) + !$EXP[flix_age_rating_legacy_available]]</visible>
						<control type="image">
							<width>97</width>
							<height>43</height>
							<texture border="8">special://skin/extras/flix-pill-bg.png</texture>
						</control>
						<control type="label">
							<left>8</left>
							<width>81</width>
							<height>43</height>
							<align>center</align>
							<aligny>center</aligny>
							<font>font20_title</font>
							<label>$INFO[ListItem.MPAA]</label>
						</control>
					</control>
					<control type="image">
						<left>27</left>
						<width>43</width>
						<height>43</height>
						<aspectratio align="center" aligny="center">keep</aspectratio>
						<texture>$VAR[FlixAgeRatingNewIconVar]</texture>
						<visible>String.IsEqual(Skin.String(Kodiflix.AgeRatingStyle),New) + $EXP[flix_age_rating_new_available]</visible>
					</control>
					<control type="image">
						<left>-3</left>
						<top>-13</top>
						<width>102</width>
						<height>69</height>
						<aspectratio align="center" aligny="center">keep</aspectratio>
						<texture>$VAR[FlixAgeRatingLegacyIconVar]</texture>
						<visible>String.IsEqual(Skin.String(Kodiflix.AgeRatingStyle),Legacy) + $EXP[flix_age_rating_legacy_available]</visible>
					</control>
				</control>
				<!-- TV show summary chips -->
				<control type="group">
					<width>120</width>
					<visible>String.IsEqual(ListItem.DBType,tvshow) + !String.IsEmpty(ListItem.Year)</visible>
					<control type="image">
						<width>120</width>
						<height>43</height>
						<texture border="8">special://skin/extras/flix-pill-bg.png</texture>
					</control>
					<control type="label">
						<left>8</left>
						<width>104</width>
						<height>43</height>
						<align>center</align>
						<aligny>center</aligny>
						<font>font20_title</font>
						<label>$INFO[ListItem.Year]</label>
					</control>
				</control>
				<control type="group">
					<width>160</width>
					<visible>String.IsEqual(ListItem.DBType,tvshow) + !String.IsEmpty(ListItem.Property(TotalSeasons))</visible>
					<control type="image">
						<width>160</width>
						<height>43</height>
						<texture border="8">special://skin/extras/flix-pill-bg.png</texture>
					</control>
					<control type="label">
						<left>8</left>
						<width>144</width>
						<height>43</height>
						<align>center</align>
						<aligny>center</aligny>
						<font>font20_title</font>
						<label>$INFO[ListItem.Property(TotalSeasons),, SEASONS]</label>
					</control>
				</control>
				<include content="FlixCentredAgeRatingControl">
					<param name="visible" value="String.IsEqual(ListItem.DBType,tvshow) + !String.IsEmpty(ListItem.MPAA) + [String.IsEmpty(Skin.String(Kodiflix.AgeRatingPosition)) | String.IsEqual(Skin.String(Kodiflix.AgeRatingPosition),Center)]" />
				</include>
				<control type="group">
					<width>190</width>
					<visible>String.IsEqual(ListItem.DBType,tvshow) + !String.IsEmpty(ListItem.Status)</visible>
					<control type="image">
						<width>190</width>
						<height>43</height>
						<texture border="8">special://skin/extras/flix-pill-bg.png</texture>
					</control>
					<control type="label">
						<left>8</left>
						<width>174</width>
						<height>43</height>
						<align>center</align>
						<aligny>center</aligny>
						<font>font20_title</font>
						<label>$INFO[ListItem.Status]</label>
					</control>
				</control>
				<!-- Season summary chips -->
				<control type="group">
					<width>150</width>
					<visible>String.IsEqual(ListItem.DBType,season) + !String.IsEmpty(ListItem.Season)</visible>
					<control type="image">
						<width>150</width>
						<height>43</height>
						<texture border="8">special://skin/extras/flix-pill-bg.png</texture>
					</control>
					<control type="label">
						<left>8</left>
						<width>134</width>
						<height>43</height>
						<align>center</align>
