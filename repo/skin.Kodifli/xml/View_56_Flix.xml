				<width>263</width>
				<height>396</height>
				<aspectratio scalediffuse="false">scale</aspectratio>
				<texture background="true" diffuse="special://skin/extras/flix-poster-mask-v4.png" fallback="DefaultMovies.png">$VAR[PosterThumbVar]</texture>
			</control>
			<control type="progress">
				<left>24</left>
				<top>424</top>
				<width>245</width>
				<height>4</height>
